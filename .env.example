# Supabase bağlantı bilgileri
# Bu dosyayı .env.local olarak kopyalayın ve gerçek değerleri girin
# .env.local asla Git'e commit edilmemeli!

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub publish ayarlari (setup:publish icin gerekli)
GH_OWNER=your-github-username-or-org
GH_REPO=your-repo-name
# Kisisel erisim belirteci (repo izinli)
GH_TOKEN=your-github-token
